  "classmate": [
    {
      "name": "System",
      "description": "Represents a complete software system as the highest boundary.",
      "business_ontology_properties_list": [
        {
          "property_key": "name",
          "note": "Required; string. Canonical business name used for display and reference. Do not use technical IDs, paths, table names, or implementation details."
        },
        {
          "property_key": "description",
          "note": "Required; string. Defines the semantic boundary and business definition of the node. Do not repeat name and do not include process steps."
        },
        {
          "property_key": "content",
          "note": "Required; string. Capture system-level boundary information: system goals, covered business domains, external system boundaries, global constraints, and governance scope."
        }
      ]
    },
    {
      "name": "Project",
      "description": "Represents an independent engineering unit inside a system.",
      "business_ontology_properties_list": [
        {
          "property_key": "name",
          "note": "Required; string. Canonical business name used for display and reference. Do not use technical IDs, paths, table names, or implementation details."
        },
        {
          "property_key": "description",
          "note": "Required; string. Defines the semantic boundary and business definition of the node. Do not repeat name and do not include process steps."
        },
        {
          "property_key": "content",
          "note": "Required; string. Capture project-level information: project responsibilities, service boundaries, key upstream/downstream dependencies, and deployment/maintenance ownership boundaries."
        }
      ]
    },
    {
      "name": "Module",
      "description": "Represents a stable implementation unit inside a project.",
      "business_ontology_properties_list": [
        {
          "property_key": "name",
          "note": "Required; string. Canonical business name used for display and reference. Do not use technical IDs, paths, table names, or implementation details."
        },
        {
          "property_key": "description",
          "note": "Required; string. Defines the semantic boundary and business definition of the node. Do not repeat name and do not include process steps."
        },
        {
          "property_key": "content",
          "note": "Required; string. Capture module-level information: module responsibilities, core capabilities, input/output business objects, and collaboration with other modules."
        }
      ]
    },
    {
      "name": "BusinessObject",
      "description": "Business semantic subject directly processed by the system.",
      "business_ontology_properties_list": [
        {
          "property_key": "name",
          "note": "Required; string. Canonical business name used for display and reference. Do not use technical IDs, paths, table names, or implementation details."
        },
        {
          "property_key": "description",
          "note": "Required; string. Defines the semantic boundary and business definition of the node. Do not repeat name and do not include process steps."
        },
        {
          "property_key": "content",
          "note": "Required; string. Capture business-object semantics: business definition, key identifying elements, lifecycle highlights, and semantic distinctions from other objects."
        }
      ]
    },
    {
      "name": "BusinessProcess",
      "description": "Stable process unit that acts on business objects and drives their creation, change, validation, routing, termination, or recovery within a business context.",
      "business_ontology_properties_list": [
        {
          "property_key": "name",
          "note": "Required; string. Use a concrete business action or process-unit name for display and reference. Prefer names such as 'Create Order', 'Approve Order', 'Allocate Inventory', or 'Confirm Receipt'. Avoid overly broad stage names such as 'Order Management', 'Inbound Process', or other end-to-end flow labels."
        },
        {
          "property_key": "description",
          "note": "Required; string. Defines the semantic boundary and business meaning of the process unit. State which business object it acts on, what business change it performs, and where its responsibility starts and ends. Do not repeat the name and do not expand into a long end-to-end process narrative."
        },
        {
          "property_key": "content",
          "note": "Required; string. Capture process semantics: trigger conditions, target business object, key preconditions, main business rules, produced or consumed artifacts, state changes, and success or failure outcomes."
        }
      ]
    },
    {
      "name": "SourceArtifact",
      "description": "Stable information carrier referenced or produced during processing.",
      "business_ontology_properties_list": [
        {
          "property_key": "name",
          "note": "Required; string. Canonical business name used for display and reference. Do not use technical IDs, paths, table names, or implementation details."
        },
        {
          "property_key": "description",
          "note": "Required; string. Defines the semantic boundary and business definition of the node. Do not repeat name and do not include process steps."
        },
        {
          "property_key": "content",
          "note": "Required; string. Capture artifact semantics: purpose, source and destination, key information carried, and creation/update timing."
        }
      ]
    },
    {
      "name": "APIEndpoint",
      "description": "Stable API contract endpoint that exposes or consumes business capabilities across module, application, or integration boundaries.",
      "business_ontology_properties_list": [
        {
          "property_key": "name",
          "note": "Required; string. Canonical endpoint name used for display and reference. Normalize the OpenAPI summary into a stable business-facing endpoint name instead of using the raw path as the primary display name."
        },
        {
          "property_key": "summary",
          "note": "Required; string. Preserve the original OpenAPI summary from the Apifox index so the ontology can serve as a fast API contract index."
        },
        {
          "property_key": "description",
          "note": "Required; string. Integrated business-facing endpoint description distilled from the Apifox operation definition. Explain the business capability and boundary without merely repeating the summary or raw path."
        },
        {
          "property_key": "content",
          "note": "Optional; string. Use only when preserving longer operation context is helpful for fast reuse, such as key request or response semantics, important constraints, or a compact copy of the operation text."
        },
        {
          "property_key": "path",
          "note": "Required; string. Canonical API route template from OpenAPI, such as '/outbound/wms-pick-suggest/rebuild/by-task/{taskId}'."
        },
        {
          "property_key": "method",
          "note": "Required; string. HTTP operation verb from OpenAPI such as GET, POST, PUT, DELETE, or PATCH."
        },
        {
          "property_key": "openapi_operation_ref",
          "note": "Required; string. Stable local reference to the concrete Apifox operation definition, including file path and method fragment, such as 'apifox/project-4853761-wms-3.0/paths/_wms_outbound_wms-pick-suggest_rebuild_by-task_%7BtaskId%7D.json#post'."
        },
        {
          "property_key": "api_level",
          "note": "Optional; string. API abstraction layer derived from the Apifox tag and path convention. Use 'level1' for atomic backend APIs that mainly expose raw record fields such as ids, codes, and statuses; use 'level2' for BAM/BFF APIs that expose enriched read models, display names, and aggregated context."
        },
        {
          "property_key": "api_audience",
          "note": "Optional; string. API audience boundary. Use 'internal' for internal WMS APIs used by internal services, apps, or BFF layers; use 'public' for external-facing APIs intended for customers or partners. This property is independent from api_level."
        }
      ]
    },
    {
      "name": "State",
      "description": "Lifecycle phase of an object or process.",
      "business_ontology_properties_list": [
        {
          "property_key": "name",
          "note": "Required; string. Canonical business name used for display and reference. Do not use technical IDs, paths, table names, or implementation details."
        },
        {
          "property_key": "description",
          "note": "Required; string. Defines the semantic boundary and business definition of the node. Do not repeat name and do not include process steps."
        },
        {
          "property_key": "content",
          "note": "Required; string. Capture state semantics: state definition, entry conditions, executable actions, and allowed next states."
        }
      ]
    },
    {
      "name": "Rule",
      "description": "Stable judgment or constraint unit for validation and decisions.",
      "business_ontology_properties_list": [
        {
          "property_key": "name",
          "note": "Required; string. Canonical business name used for display and reference. Do not use technical IDs, paths, table names, or implementation details."
        },
        {
          "property_key": "description",
          "note": "Required; string. Defines the semantic boundary and business definition of the node. Do not repeat name and do not include process steps."
        },
        {
          "property_key": "content",
          "note": "Required; string. Capture rule semantics: rule objective, decision conditions, constrained objects, post-hit actions, and exceptions."
        }
      ]
    }
